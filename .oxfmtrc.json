{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["dist", ".next", "node_modules", "bun.lock", "*.tsbuildinfo"],
  "sortPackageJson": {},
  "sortImports": {
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      "unknown"
    ]
  },
  "sortTailwindcss": {
    "functions": ["cn", "clsx"]
  }
}
