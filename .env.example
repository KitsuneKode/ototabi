# ─── PostgreSQL ───
DATABASE_URL="postgresql://user:password@localhost:5432/ototabi?schema=public"

# ─── API Server ───
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=

# ─── Better Auth ───
BETTER_AUTH_SECRET=generate-a-random-secret-here
# Public URL clients use for /api/auth (browser origin). Handler still runs on the API.
# Dev: Next :3000 proxies /api/auth → Express :8080, so this is :3000 not :8080.
BETTER_AUTH_URL=http://localhost:3000

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── LiveKit Cloud ───
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ─── Redis (BullMQ worker queue) ───
REDIS_URL=redis://localhost:6379

# ─── AI / OpenAI (optional — worker features) ───
# Without OPENAI_API_KEY, transcript and LLM jobs are skipped.
# Worker still runs, just processes no-op.
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
LLM_MODEL=gpt-4o-mini

# ─── Polar.sh Billing (optional) ───
# Without POLAR_ACCESS_TOKEN, subscriptions default to free trial mode.
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_PRODUCT_CREATOR=
POLAR_PRODUCT_PRO=
POLAR_PRODUCT_STUDIO=

# ─── S3 / R2 / MinIO ───
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET_NAME=ototabi-recordings
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT=http://localhost:9000

# ─── Client (NEXT_PUBLIC_*) ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_AWS_ACCESS_KEY_ID=minioadmin
NEXT_PUBLIC_AWS_SECRET_ACCESS_KEY=minioadmin
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_S3_BUCKET_NAME=ototabi-recordings
