# ─── PostgreSQL ───
DATABASE_URL="postgresql://user:password@localhost:5432/ototabi?schema=public"

# ─── API Server ───
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Staging/production: comma-separated Vercel origins (preview + production, no trailing slash)
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app-git-branch.vercel.app
ALLOWED_ORIGINS=
# Client → API. Dev: Express :8080. Staging/prod: Railway API public URL (not Vercel).
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Better Auth ───
BETTER_AUTH_SECRET=generate-a-random-secret-here
# Browser origin for auth cookies/URLs — NOT the Railway API host in split deploy.
# Dev: http://localhost:3000 (Next proxies /api/auth → Express).
# Staging/prod: https://your-app.vercel.app (same as FRONTEND_URL / NEXT_PUBLIC_APP_URL).
BETTER_AUTH_URL=http://localhost:3000

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── LiveKit Cloud ───
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ─── Redis (BullMQ worker queue) ───
REDIS_URL=redis://localhost:6379

# ─── AI / OpenAI (optional — worker features) ───
# Without OPENAI_API_KEY, transcript and LLM jobs are skipped.
# Worker still runs, just processes no-op.
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
LLM_MODEL=gpt-4o-mini

# ─── Dodo Payments Billing (optional) ───
# Without DODO_PAYMENTS_API_KEY, subscriptions default to free trial mode.
DODO_PAYMENTS_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PRODUCT_CREATOR=
DODO_PRODUCT_PRO=
DODO_PRODUCT_STUDIO=

# ─── S3 / R2 / MinIO ───
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET_NAME=ototabi-recordings
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT=http://localhost:9000

# ─── Client (NEXT_PUBLIC_*) ───
# Staging/prod: Vercel deployment URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Staging/prod: Railway API URL (tRPC, uploads, LiveKit token)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_AWS_ACCESS_KEY_ID=minioadmin
NEXT_PUBLIC_AWS_SECRET_ACCESS_KEY=minioadmin
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_S3_BUCKET_NAME=ototabi-recordings
