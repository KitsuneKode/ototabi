// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id
  name               String
  email              String
  emailVerified      Boolean
  image              String?
  role               String              @default("user")
  subscription       Subscription?
  createdAt          DateTime
  updatedAt          DateTime
  sessions           Session[]
  accounts           Account[]
  rooms              Room[]
  tracks             RecordingTrack[]
  uploadSessions     UploadSession[]
  recordingEvents    RecordingEvent[]
  roomParticipations RoomParticipant[]
  roomMemberships    RoomMember[]
  studioJoinRequests StudioJoinRequest[]
  chatMessages       ChatMessage[]
  usageCounters      UsageCounter[]

  @@unique([email])
  @@map("user")
}

/// Per-user usage counters for plan caps (trial transcript teaser, clip monthly, etc.).
model UsageCounter {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String // TRANSCRIPT_LIFETIME | CLIPS_MONTH
  periodKey String   @default("") // YYYY-MM for monthly; empty string for lifetime
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, kind, periodKey])
  @@index([userId, kind])
  @@map("usage_counter")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Room {
  id           String              @id @default(cuid())
  name         String
  code         String              @unique
  creatorId    String
  isLocked     Boolean             @default(false)
  creator      User                @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  sessions     RecordingSession[]
  participants RoomParticipant[]
  members      RoomMember[]
  invites      RoomInvite[]
  joinRequests StudioJoinRequest[]
  chatMessages ChatMessage[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([creatorId])
  @@map("room")
}

model StudioJoinRequest {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("pending") // pending | admitted | denied
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, userId])
  @@index([roomId, status])
  @@map("studio_join_request")
}

model RoomInvite {
  id        String    @id @default(cuid())
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  role      String    @default("participant") // participant | editor | viewer
  email     String?
  maxUses   Int?
  usedCount Int       @default(0)
  expiresAt DateTime?
  revokedAt DateTime?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([roomId, revokedAt])
  @@map("room_invite")
}

model RoomMember {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("editor") // host | editor | viewer
  invitedBy String?
  joinedAt  DateTime @default(now())

  @@unique([roomId, userId])
  @@map("room_member")
}

model RoomParticipant {
  id                   String    @id @default(cuid())
  roomId               String
  room                 Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt             DateTime  @default(now())
  recordingConsentedAt DateTime?

  @@unique([roomId, userId])
  @@map("room_participant")
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  message   String
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@map("chat_message")
}

model RecordingSession {
  id                 String              @id @default(cuid())
  roomId             String
  room               Room                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  mode               String              @default("STUDIO") // "STUDIO" | "DEMO"
  status             String // "RECORDING" | "COMPLETED"
  demoData           DemoSessionData?
  tracks             RecordingTrack[]
  uploadSessions     UploadSession[]
  events             RecordingEvent[]
  syncMarkers        SyncMarker[]
  transcriptSegments TranscriptSegment[]
  chapters           Chapter[]
  showNotes          ShowNotes?
  clipCandidates     ClipCandidate[]
  episodeMp3Status   String              @default("pending")
  episodeMp3S3Key    String?
  episodeMp3Error    String?
  landscapeStatus    String              @default("pending")
  landscapeS3Key     String?
  landscapeError     String?
  transcriptStatus   String              @default("pending") // pending | processing | ready | failed | skipped
  transcriptError    String?
  llmStatus          String              @default("pending")
  llmError           String?
  clipsStatus        String              @default("pending")
  clipsError         String?
  startedAt          DateTime            @default(now())
  endedAt            DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([roomId, startedAt])
  @@map("recording_session")
}

model DemoSessionData {
  id           String           @id @default(cuid())
  sessionId    String           @unique
  session      RecordingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  cursorEvents Json             @default("[]")
  zoomRegions  Json             @default("[]")
  trimStartMs    Float?
  trimEndMs      Float?
  playbackSpeed  Float            @default(1)
  backgroundBlur Int              @default(0)
  pipEnabled     Boolean          @default(true)
  background     Json             @default("{\"type\":\"solid\",\"value\":\"#0a0a0a\"}")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("demo_session_data")
}

model RecordingTrack {
  id        String           @id @default(cuid())
  sessionId String
  session   RecordingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackSid  String // LiveKit track SID
  type      String // "CAMERA" | "SCREENSHARE" | "MICROPHONE"
  status    String // "PENDING" | "UPLOADING" | "COMPLETED" | "FAILED"
  s3Key     String
  s3Url     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([sessionId])
  @@map("recording_track")
}

model UploadSession {
  id          String           @id @default(cuid())
  sessionId   String
  session     RecordingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackSid    String
  type        String // "CAMERA" | "SCREENSHARE" | "MICROPHONE"
  uploadId    String
  s3Key       String           @unique
  status      String           @default("UPLOADING") // "UPLOADING" | "COMPLETED" | "FAILED"
  parts       Json             @default("[]")
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([sessionId, trackSid])
  @@index([userId, status])
  @@map("upload_session")
}

model SyncMarker {
  id           String           @id @default(cuid())
  sessionId    String
  session      RecordingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId       String
  localTime    Float
  rtpTimestamp Float?
  trackSid     String?
  createdAt    DateTime         @default(now())

  @@index([sessionId, userId])
  @@index([sessionId, createdAt])
  @@map("sync_marker")
}

model RecordingEvent {
  id         String           @id @default(cuid())
  sessionId  String
  session    RecordingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  type       String // START | STOP | PAUSE | RESUME | JOIN | LEAVE | RECONNECT | TRACK_PUBLISHED | TRACK_UNPUBLISHED | UPLOAD_COMPLETED
  trackSid   String?
  message    String?
  metadata   Json             @default("{}")
  occurredAt DateTime         @default(now())
  createdAt  DateTime         @default(now())

  @@index([sessionId, occurredAt])
  @@index([sessionId, type])
  @@map("recording_event")
}

model TranscriptSegment {
  id         String           @id @default(cuid())
  sessionId  String
  userId     String?
  startTime  Float
  endTime    Float
  text       String
  confidence Float?
  createdAt  DateTime         @default(now())
  session    RecordingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, startTime])
  @@map("transcript_segment")
}

model Chapter {
  id        String           @id @default(cuid())
  sessionId String
  title     String
  startTime Float
  endTime   Float?
  createdAt DateTime         @default(now())
  session   RecordingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chapter")
}

model ShowNotes {
  id        String           @id @default(cuid())
  sessionId String           @unique
  summary   String           @db.Text
  keywords  Json             @default("[]")
  seoTitles Json             @default("[]")
  createdAt DateTime         @default(now())
  session   RecordingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("show_notes")
}

model ClipCandidate {
  id           String           @id @default(cuid())
  sessionId    String
  session      RecordingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  startTime    Float
  endTime      Float
  score        Float
  rationale    String           @db.Text
  layout       String           @default("vertical_9_16")
  renderStatus String           @default("pending")
  renderS3Key  String?
  renderError  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([sessionId, score])
  @@map("clip_candidate")
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  plan             Plan               @default(TRIAL)
  status           SubscriptionStatus @default(TRIALING)
  stripeCustomerId String?
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscription")
}

enum Plan {
  TRIAL
  CREATOR
  PRO
  STUDIO
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}
