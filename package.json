{
  "name": "ototabi",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling/*",
      "tests"
    ],
    "catalog": {
      "@prisma/adapter-pg": "7.8.0",
      "@prisma/client": "7.8.0",
      "@t3-oss/env-core": "^0.13.11",
      "@t3-oss/env-nextjs": "^0.13.11",
      "@trpc/client": "^11.4.3",
      "@trpc/server": "^11.4.3",
      "@trpc/tanstack-react-query": "^11.4.3",
      "@types/bun": "latest",
      "@types/node": "^25.9.1",
      "@types/react": "19.2.15",
      "@types/react-dom": "19.2.3",
      "better-auth": "^1.2.12",
      "pg": "^8.16.0",
      "prisma": "7.8.0",
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "typescript": "6.0.3",
      "zod": "^4.4.3"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "db:generate": "turbo run db:generate --filter=@ototabi/store",
    "db:migrate": "turbo run db:migrate --filter=@ototabi/store",
    "db:studio": "turbo run db:studio --filter=@ototabi/store",
    "lint": "oxlint --report-unused-disable-directives",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "turbo run typecheck",
    "check": "bun run fmt:check && bun lint && bun typecheck && bun run test",
    "test": "turbo run test",
    "prepare": "husky",
    "preinstall": "npx only-allow bun",
    "postinstall": "turbo run db:generate --filter=@ototabi/store"
  },
  "devDependencies": {
    "@types/minimatch": "^6.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "turbo": "^2.5.6",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxfmt",
      "oxlint --fix --report-unused-disable-directives"
    ],
    "*.{json,md,css}": [
      "oxfmt"
    ],
    "*.prisma": [
      "bash -c 'cd packages/store && bunx prisma format'"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.12"
}
