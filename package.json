{
  "name": "ototabi",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*",
    "tests"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio",
    "lint": "oxlint --report-unused-disable-directives",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "prepare": "husky",
    "preinstall": "npx only-allow bun",
    "postinstall": "turbo run db:generate"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.2",
    "@hookform/resolvers": "^5.0.1",
    "@polar-sh/sdk": "^0.47.1",
    "@t3-oss/env-core": "^0.13.11",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tabler/icons-react": "^3.44.0",
    "date-fns": "^4.3.0",
    "express-rate-limit": "^8.5.2",
    "react-hook-form": "^7.57.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/minimatch": "^6.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "turbo": "^2.5.6",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css}": [
      "oxfmt",
      "oxlint --fix --report-unused-disable-directives"
    ],
    "*.prisma": [
      "bash -c 'cd packages/store && bunx prisma format --schema prisma/schema.prisma'"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.15"
}
